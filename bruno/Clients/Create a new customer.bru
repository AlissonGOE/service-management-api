info:
  name: Create a new customer
  type: http
  seq: 2

http:
  method: POST
  url: {{baseUrl}}/clients
  body:
    type: json
    data: |-
      {
        "name": "String",
        "phone": "String"
      }
  auth: inherit

settings:
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
